                "SGL_MAX_POLYGONS=1700",
                "SGL_MAX_EVENTS=64",
                "SGL_MAX_WORKS=256"
            ],
            "compilerPath": "/opt/saturn/toolchain/bin/sh-elf-g++",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "intelliSenseMode": "gcc-x64",
            "compilerArgs": [
                "-m2",
                "-fno-rtti",
                "-fno-exceptions",
                "-fno-builtin"
            ]
        }
    ],
    "version": 4
